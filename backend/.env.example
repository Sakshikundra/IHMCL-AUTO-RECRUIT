# Copy this file to .env and fill in real values before running the server.

# ── Gemini ────────────────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash

# ── Auth ──────────────────────────────────────────────────────────────────
# Generate a strong random value for production, e.g.: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change_this_to_a_long_random_string
JWT_ALGORITHM=HS256
COOKIE_NAME=access_token
COOKIE_MAX_AGE_DAYS=30
COOKIE_SECURE=false

# ── Database ──────────────────────────────────────────────────────────────
DATABASE_URL=sqlite:///./recruit.db

# ── Server / CORS ─────────────────────────────────────────────────────────
FRONTEND_ORIGIN=http://localhost:5173
PORT=3001
